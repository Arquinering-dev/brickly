generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model APU {
  id               String   @id @default(uuid())
  nombre           String
  fechaImportacion DateTime @default(now())
  mesBaseCAC       String
  cacBase          Decimal  @db.Decimal(12, 4)
  coefCargasMO     Decimal  @db.Decimal(8, 4)
  ggPercent        Decimal  @db.Decimal(8, 4)
  bbPercent        Decimal  @db.Decimal(8, 4)

  materiales       Material[]
  manosDeObra      ManoDeObra[]
  equipos          Equipo[]
  partidas         Partida[]
  presupuestoLineas PresupuestoLinea[]
}

model Material {
  id          String  @id @default(uuid())
  codigo      String  @unique
  descripcion String
  unidad      String
  precio      Decimal @db.Decimal(14, 4)
  proveedor   String?
  categoria   String?
  apuId       String

  apu          APU                  @relation(fields: [apuId], references: [id], onDelete: Cascade)
  composiciones ComposicionPartida[] @relation("MaterialComposicion")
}

model ManoDeObra {
  id           String  @id @default(uuid())
  codigo       String  @unique
  descripcion  String
  salarioDia   Decimal @db.Decimal(14, 4)
  coefCargas   Decimal @db.Decimal(8, 4)
  tipo         String
  apuId        String

  apu          APU                  @relation(fields: [apuId], references: [id], onDelete: Cascade)
  composiciones ComposicionPartida[] @relation("ManoDeObraComposicion")
}

model Equipo {
  id          String  @id @default(uuid())
  codigo      String  @unique
  descripcion String
  costoTotal  Decimal @db.Decimal(14, 4)
  vidaDias    Int
  costoDia    Decimal @db.Decimal(14, 4)
  apuId       String

  apu          APU                  @relation(fields: [apuId], references: [id], onDelete: Cascade)
  composiciones ComposicionPartida[] @relation("EquipoComposicion")
}

model Partida {
  id                      String  @id @default(uuid())
  codigo                  String  @unique
  rubro                   String
  descripcion             String
  unidad                  String
  rendimiento             Decimal @db.Decimal(14, 4)
  pctDesperdicioConsumibles Decimal @db.Decimal(8, 4) @default(0)
  pctDesperdicioGeneral   Decimal @db.Decimal(8, 4) @default(0)
  gradoDificultad         Int     @default(1)
  matUnitario             Decimal @db.Decimal(14, 4) @default(0)
  moUnitario              Decimal @db.Decimal(14, 4) @default(0)
  eqUnitario              Decimal @db.Decimal(14, 4) @default(0)
  cdUnitario              Decimal @db.Decimal(14, 4) @default(0)
  apuId                   String

  apu              APU                @relation(fields: [apuId], references: [id], onDelete: Cascade)
  composiciones    ComposicionPartida[]
  presupuestoLineas PresupuestoLinea[]
}

enum TipoInsumo {
  MATERIAL
  MANO_DE_OBRA
  EQUIPO
}

model ComposicionPartida {
  id               String     @id @default(uuid())
  partidaId        String
  tipo             TipoInsumo
  insumoId         String
  cantidadPorUnidad Decimal   @db.Decimal(14, 6)
  pctDesperdicio   Decimal    @db.Decimal(8, 4) @default(0)
  secuencia        Int        @default(0)

  partida    Partida     @relation(fields: [partidaId], references: [id], onDelete: Cascade)
  material   Material?   @relation("MaterialComposicion", fields: [insumoId], references: [id], map: "composicion_material_fk")
  manoDeObra ManoDeObra? @relation("ManoDeObraComposicion", fields: [insumoId], references: [id], map: "composicion_mo_fk")
  equipo     Equipo?     @relation("EquipoComposicion", fields: [insumoId], references: [id], map: "composicion_equipo_fk")
}

model PresupuestoLinea {
  id        String  @id @default(uuid())
  apuId     String
  partidaId String
  cantidad  Decimal @db.Decimal(14, 4)
  matTotal  Decimal @db.Decimal(14, 4) @default(0)
  moTotal   Decimal @db.Decimal(14, 4) @default(0)
  eqTotal   Decimal @db.Decimal(14, 4) @default(0)
  estado    String  @default("activo")

  apu     APU     @relation(fields: [apuId], references: [id], onDelete: Cascade)
  partida Partida @relation(fields: [partidaId], references: [id], onDelete: Cascade)
}
