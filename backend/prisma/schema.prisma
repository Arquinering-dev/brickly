generator client {
  provider      = "prisma-client-js"
  // "native" para dev local (macOS); el target musl-openssl-3.0.x es para el runtime en
  // node:20-alpine (Railway), que trae OpenSSL 3 — sin esto el schema engine no carga libssl.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  nombre    String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TipoInsumo {
  MATERIAL
  MANO_DE_OBRA
  EQUIPO
  SUBCONTRATO
}

enum TipoPartida {
  APU
  SUBCONTRATO
  COTIZACION_DIRECTA
}

enum EstadoObra {
  EN_PRESUPUESTO
  EN_CURSO
  FINALIZADA
}

enum ScopePartida {
  APU
  OBRA
}

enum TipoPresupuesto {
  GENERADOR
  APROBADO
}

model Insumo {
  id                  String        @id @default(uuid())
  codigo              String        @unique
  descripcion         String
  tipo                TipoInsumo
  unidad              String
  precioReferencia    Decimal       @db.Decimal(18, 2)
  proveedor           String?
  // Categoría cruda tal cual viene del Excel (col "Categoría"). Puede ser ruidosa o vacía.
  categoria           String?
  // Categoría canónica asignada por el clasificador Gemini al importar (write-time, persistida).
  // La vista de proyección agrupa por este campo: categoriaCanonica ?? categoria ?? "Sin categoría".
  // El bulk-upsert del importador NO la pisa en re-imports, así que el trabajo de IA persiste.
  categoriaCanonica   String?
  codigoOriginal      String?
  fechaCotizacion     DateTime?
  // Embedding semántico generado con Gemini text-embedding-004 (768 dims).
  // Se usa para detectar insumos duplicados con descripciones distintas.
  embedding           Float[]       @default([])
  embeddingUpdatedAt  DateTime?
  // Fingerprint del texto que produjo el embedding (descripcion+unidad+tipo).
  // Si cambia, el embedding está obsoleto y se regenera.
  embeddingSource     String?
  // Trazabilidad de modificaciones IA:
  // null = dato original del Excel | "ia" = categoría asignada automáticamente por IA
  fuenteCategoria     String?
  composiciones       Composicion[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Partida {
  id                String             @id @default(uuid())
  codigo            String             @unique
  descripcion       String
  rubro             String
  unidad            String
  rendimiento       Decimal?           @db.Decimal(10, 4)
  tipo              TipoPartida        @default(APU)
  scope             ScopePartida       @default(APU)
  obraId            String?
  activa            Boolean            @default(true)
  composiciones     Composicion[]
  lineasPresupuesto LineaPresupuesto[]
  obra              Obra?              @relation(fields: [obraId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([scope, obraId])
}

model Composicion {
  id                String   @id @default(uuid())
  partidaId         String
  insumoId          String
  cantidadPorUnidad Decimal  @db.Decimal(14, 6)
  pctDesperdicio    Decimal  @db.Decimal(6, 4)
  secuencia         Int      @default(0)
  partida           Partida  @relation(fields: [partidaId], references: [id], onDelete: Cascade)
  insumo            Insumo   @relation(fields: [insumoId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Obra {
  id                String             @id @default(uuid())
  nombre            String
  codigo            String             @unique
  fechaInicio       DateTime?
  estado            EstadoObra         @default(EN_PRESUPUESTO)
  coefGGBB          Decimal?           @db.Decimal(12, 8)
  mesCacBase        String?
  valorCacBase      Decimal?           @db.Decimal(14, 2)
  costoControlable  Decimal?           @db.Decimal(18, 2)
  precioVentaTotal  Decimal?           @db.Decimal(18, 2)
  aperturaBlancoP   Decimal?           @db.Decimal(5, 2)
  aperturaNegrop    Decimal?           @db.Decimal(5, 2)
  centroCosto       String?
  presupuestos      PresupuestoHeader[]
  lineasPresupuesto LineaPresupuesto[]
  partidas          Partida[]
  movimientos       Movimiento[]
  subcontratos      SubcontratoObra[]
  contratos         ContratoCliente[]
  quincenas         Quincena[]
  gastosDirInd      GastoDirInd[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PresupuestoHeader {
  id              String             @id @default(uuid())
  obraId          String
  tipo            TipoPresupuesto    @default(GENERADOR)
  fecha           DateTime
  cacValor        Decimal            @db.Decimal(12, 2)
  mesCac          String
  estado          String             @default("vigente")
  nombre          String?
  version         String?
  coefGGBB        Decimal?           @db.Decimal(8, 4)
  // Fecha absoluta del primer mes con datos en el cronograma aprobado.
  // Se completa al importar el "Presupuesto Aprobado + Cronograma".
  fechaInicio     DateTime?
  obra            Obra               @relation(fields: [obraId], references: [id])
  lineas          LineaPresupuesto[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model LineaPresupuesto {
  id                     String            @id @default(uuid())
  obraId                 String
  presupuestoHeaderId    String
  partidaId              String?
  cantidad               Decimal           @db.Decimal(14, 4)
  precioUnitarioSnapshot Decimal           @db.Decimal(18, 2)
  tipo                   TipoPartida       @default(APU)
  descripcionLibre       String?
  estadoItem             String            @default("OK")
  rubro                  String
  subRubro               String?
  itemNumero             String?
  orden                  Int               @default(0)
  matUd                  Decimal?          @db.Decimal(18, 2)
  moUd                   Decimal?          @db.Decimal(18, 2)
  eqUd                   Decimal?          @db.Decimal(18, 2)
  precioVenta            Decimal?          @db.Decimal(18, 2)
  fuente                 String?
  apuLinkCodigo          String?
  // true si la IA normalizó el nombre del rubro al importar (ej: "H.A." → "Hormigón Armado")
  rubroNormalizado       Boolean           @default(false)
  costoMtUd              Decimal?          @db.Decimal(18, 2)
  costoMoOtrUd           Decimal?          @db.Decimal(18, 2)
  costoMoAlbUd           Decimal?          @db.Decimal(18, 2)
  costoEqUd              Decimal?          @db.Decimal(18, 2)
  pvMtUd                 Decimal?          @db.Decimal(18, 2)
  pvMoOtrUd              Decimal?          @db.Decimal(18, 2)
  pvMoAlbUd              Decimal?          @db.Decimal(18, 2)
  pvEqUd                 Decimal?          @db.Decimal(18, 2)
  pctCertificado         Decimal?          @db.Decimal(8, 6)
  rubroMt                String?
  rubroMoOtr             String?
  rubroMoAlb             String?
  etapa                  String?
  cronograma             LineaCronograma[]
  avances                AvanceReporte[]
  certificacionLineas    CertificacionLinea[]
  obra                   Obra              @relation(fields: [obraId], references: [id])
  presupuestoHeader      PresupuestoHeader @relation(fields: [presupuestoHeaderId], references: [id])
  partida                Partida?          @relation(fields: [partidaId], references: [id])
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
}

// Índice del Costo de la Construcción (ICC) publicado mensualmente por INDEC.
// Se pobla automáticamente al iniciar el servidor (best-effort) y vía POST /api/indices/icc/fetch.
model IndiceICC {
  id               String   @id @default(uuid())
  mes              Int      // 1-12
  anio             Int
  variacionMensual Decimal? @db.Decimal(8, 4)  // % vs mes anterior (nivel general)
  variacionAnual   Decimal? @db.Decimal(8, 4)  // % vs mismo mes año anterior
  // Valor absoluto del ICC nivel general (base Oct 2015 = 100).
  // Cuando está disponible permite calcular coef = valorAbsoluto / cacValorBase.
  valorAbsoluto    Decimal? @db.Decimal(16, 4)
  fuente           String   // 'argly' | 'indec_ftp' | 'indec_sipm'
  fetchedAt        DateTime
  createdAt        DateTime @default(now())

  @@unique([mes, anio])
  @@index([anio, mes])
}

// Distribución mensual de ejecución de una tarea según el cronograma aprobado.
// Los pctEjecucion de todas las filas de una misma lineaId suman ~1.0.
model LineaCronograma {
  id            String           @id @default(uuid())
  lineaId       String
  // Posición ordinal del mes en el cronograma (0, 1, 2, ...).
  // No tiene significado por sí solo — la fecha absoluta es la fuente de verdad.
  mesOrdinal    Int
  // Fecha absoluta del mes (típicamente día 1).
  fecha         DateTime
  // Fracción del trabajo total de la tarea ejecutada en ese mes [0.0, 1.0].
  pctEjecucion  Decimal          @db.Decimal(8, 6)
  linea         LineaPresupuesto @relation(fields: [lineaId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())

  @@unique([lineaId, mesOrdinal])
  @@index([fecha])
}

// Avance REAL de ejecución reportado en obra (distinto del cronograma previsto).
model AvanceReporte {
  id            String           @id @default(uuid())
  lineaId       String
  fecha         DateTime         @default(now())
  pctIncremento Decimal          @db.Decimal(8, 6)
  cantidad      Decimal?         @db.Decimal(14, 4)
  nota          String?
  linea         LineaPresupuesto @relation(fields: [lineaId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())

  @@index([lineaId])
}

model RubroContable {
  id          String       @id @default(uuid())
  codigo      String       @unique
  nombre      String
  createdAt   DateTime     @default(now())
  movimientos Movimiento[]
}

model IndiceCAC {
  id          String   @id @default(uuid())
  mes         DateTime @unique
  valorIndec  Decimal  @db.Decimal(14, 4)
  esPrevision Boolean  @default(false)
  ratio       Decimal? @db.Decimal(12, 8)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TarifaUOCRA {
  id        String   @id @default(uuid())
  mes       DateTime
  categoria String
  precioDia Decimal  @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([mes, categoria])
}

model ContratoCliente {
  id                  String          @id @default(uuid())
  obraId              String
  ocId                String
  descripcion         String?
  presupuestoAprobado Decimal         @db.Decimal(18, 2)
  pctAnticipo         Decimal         @db.Decimal(5, 2) @default(0)
  mesCacBase          String?
  indiceCACBase       Decimal?        @db.Decimal(14, 4)
  pctBlanco           Decimal         @db.Decimal(5, 2) @default(0)
  pctNegro            Decimal         @db.Decimal(5, 2) @default(0)
  pctDesacopio        Decimal         @db.Decimal(5, 2) @default(0)
  pctIVA              Decimal         @db.Decimal(5, 2) @default(0)
  presupuestoLabel    String?
  // 'import' = creado desde el Resumen de Obra (se borra y recrea en cada import);
  // 'app'    = contrato sintético para certificaciones armadas desde la web (el import NO lo toca).
  fuente              String          @default("import")
  certificaciones     Certificacion[]
  obra                Obra            @relation(fields: [obraId], references: [id], onDelete: Cascade)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  @@unique([obraId, ocId])
}

model Certificacion {
  id           String               @id @default(uuid())
  contratoId   String
  certId       String
  fecha        DateTime
  baseBruta    Decimal              @db.Decimal(18, 2)
  pctDesacopio Decimal              @db.Decimal(5, 2) @default(0)
  desacopio    Decimal              @db.Decimal(18, 2) @default(0)
  subtotalNeto Decimal              @db.Decimal(18, 2)
  estado       String               @default("emitido")
  // 'import' = importada del Resumen; 'app' = armada desde la web a partir del avance reportado.
  fuente       String               @default("import")
  // Período certificado (solo certs de app). Mes 1-12.
  periodoMes   Int?
  periodoAnio  Int?
  nota         String?
  // Inputs de la valorización formal (etapa 'valorizada'); null hasta que se valoriza.
  // El desglose (CAC / facturable-no-facturable / IVA) se computa de estos + subtotalNeto.
  pctFacturable  Decimal? @db.Decimal(6, 4)  // fracción facturable; resto = no facturable
  pctIva         Decimal? @db.Decimal(6, 4)  // IVA sobre el componente facturable
  indiceCacBase  Decimal? @db.Decimal(16, 4) // índice CAC del mes base del contrato
  indiceCacFecha Decimal? @db.Decimal(16, 4) // índice CAC del mes de la certificación
  contrato     ContratoCliente      @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  lineas       CertificacionLinea[]
  comprobantes ComprobanteCert[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  @@unique([contratoId, certId])
}

// Facturación y cobranza de una certificación valorizada (etapa final del circuito).
// 1:N: una cert puede tener varias facturas/recibos (parciales). Un comprobante está
// cobrado cuando tiene fechaCobro. Espeja la hoja Cert_Facturacion del Resumen.
model ComprobanteCert {
  id              String        @id @default(uuid())
  certificacionId String
  tipo            String        // 'factura' (facturable, c/IVA) | 'recibo' (no facturable) | 'anticipo'
  numero          String?       // nro de comprobante (ej. "FA-B 0001")
  monto           Decimal       @db.Decimal(18, 2)
  fecha           DateTime      // fecha de emisión
  fechaCobro      DateTime?     // null = pendiente de cobro
  retencion       Decimal?      @db.Decimal(18, 2)
  nota            String?
  certificacion   Certificacion @relation(fields: [certificacionId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([certificacionId])
}

model CertificacionLinea {
  id               String        @id @default(uuid())
  certificacionId  String
  codTarea         String
  pctAnterior      Decimal       @db.Decimal(8, 6) @default(0)
  pctActual        Decimal       @db.Decimal(8, 6) @default(0)
  pctTotal         Decimal       @db.Decimal(8, 6) @default(0)
  pvTotalTarea     Decimal       @db.Decimal(18, 2)
  baseCertificada  Decimal       @db.Decimal(18, 2)
  presupuestoLabel String?
  // Link robusto a la línea de presupuesto (certs de app). El import solo usa codTarea.
  lineaId          String?
  // Snapshot de la descripción de la tarea, para display estable.
  descripcion      String?
  certificacion    Certificacion     @relation(fields: [certificacionId], references: [id], onDelete: Cascade)
  linea            LineaPresupuesto? @relation(fields: [lineaId], references: [id], onDelete: SetNull)
  createdAt        DateTime          @default(now())

  @@index([lineaId])
}

model SubcontratoObra {
  id           String       @id @default(uuid())
  obraId       String
  contratoId   String       @unique
  proveedor    String
  rubro        String
  descripcion  String?
  montoPpto    Decimal      @db.Decimal(18, 2)
  ajustaCAC    Boolean      @default(false)
  pctAnticipo  Decimal?     @db.Decimal(5, 2)
  pagadoBase   Decimal      @db.Decimal(18, 2) @default(0)
  pagadoCAC    Decimal      @db.Decimal(18, 2) @default(0)
  pagadoCS     Decimal      @db.Decimal(18, 2) @default(0)
  pagadoTotal  Decimal      @db.Decimal(18, 2) @default(0)
  saldo        Decimal      @db.Decimal(18, 2) @default(0)
  pctConsumido Decimal?     @db.Decimal(5, 2)
  estado       String       @default("activo")
  obra         Obra         @relation(fields: [obraId], references: [id], onDelete: Cascade)
  movimientos  Movimiento[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Movimiento {
  id              String           @id @default(uuid())
  obraId          String
  cuentaCodigo    String
  cuentaNombre    String?
  fecha           DateTime
  nroAsiento      Int?
  observaciones   String?
  proveedor       String?
  codComprobante  String?
  nroComprobante  String?
  debe            Decimal          @db.Decimal(18, 2) @default(0)
  haber           Decimal          @db.Decimal(18, 2) @default(0)
  centroCosto     String?
  subcontratoId   String?
  movTipo         String?
  rubroContableId String?
  obra            Obra             @relation(fields: [obraId], references: [id], onDelete: Cascade)
  subcontrato     SubcontratoObra? @relation(fields: [subcontratoId], references: [id])
  rubroContable   RubroContable?   @relation(fields: [rubroContableId], references: [id])
  createdAt       DateTime         @default(now())
}

model Quincena {
  id              String   @id @default(uuid())
  obraId          String
  mes             DateTime
  periodo         String
  categoria       String
  rubro           String
  horasNormales   Decimal  @db.Decimal(10, 2) @default(0)
  horasExtra50    Decimal  @db.Decimal(10, 2) @default(0)
  horasExtra100   Decimal  @db.Decimal(10, 2) @default(0)
  costoTotal      Decimal  @db.Decimal(18, 2) @default(0)
  costoDeflactado Decimal  @db.Decimal(18, 2) @default(0)
  obra            Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  @@unique([obraId, mes, periodo, categoria, rubro])
}

model GastoDirInd {
  id        String   @id @default(uuid())
  obraId    String
  fecha     DateTime
  tipo      String
  concepto  String
  monto     Decimal  @db.Decimal(18, 2)
  obra      Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
