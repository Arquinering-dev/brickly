# ============================================
# Base de datos
# ============================================
# DATABASE_URL: la usa la app para queries (en prod usar el pooler de Supabase, puerto 6543)
# DIRECT_DATABASE_URL: la usa Prisma para migraciones (siempre conexion directa, puerto 5432)
#
# Local (Docker):
#   DATABASE_URL="postgresql://brickly:brickly@localhost:5434/brickly"
#   DIRECT_DATABASE_URL="postgresql://brickly:brickly@localhost:5434/brickly"
#
# Supabase (produccion):
#   DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
#   DIRECT_DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

DATABASE_URL="postgresql://brickly:brickly@localhost:5432/brickly"
DIRECT_DATABASE_URL="postgresql://brickly:brickly@localhost:5432/brickly"

NODE_ENV="development"
PORT=3000

# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="reemplazar-con-un-secreto-seguro"

# En produccion: CORS_ORIGIN="https://tu-app.vercel.app"
# Multiples origenes separados por coma: CORS_ORIGIN="https://tu-app.vercel.app,http://localhost:5173"
CORS_ORIGIN="http://localhost:5173"

# ============================================
# IA — Gemini (Google AI Studio)
# ============================================
# Obtener una API key gratuita en https://aistudio.google.com/apikey
# Usado para:
#   - Validación AI del archivo APU antes de importar
#   - Embeddings semánticos para detectar insumos duplicados
# Si está vacía, el sistema funciona pero las features de IA quedan deshabilitadas.
GEMINI_API_KEY=""
